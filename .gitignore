# ======================
# Environment & Secrets
# ======================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.env
.env.*
!.env.example
!.env.local.example
# frontend/.env.production não contém segredos (apenas NEXT_PUBLIC_* variáveis),
# por isso é versionado para garantir que NEXT_PUBLIC_API_URL seja sempre vazio
# em produção. Um valor não-vazio (ex: https://verus.ai) causa
# ERR_TOO_MANY_REDIRECTS porque o axios envia requests para o domínio público
# em vez de usar URLs relativas.
!frontend/.env.production

