# ========================================
# Verus.AI - Configurações de Produção
# ========================================
# ATENÇÃO: Este arquivo é apenas um TEMPLATE!
# Copie para .env e substitua todos os valores
# NUNCA commite o arquivo .env no git!
#
# Para gerar senhas seguras (30+ caracteres):
# openssl rand -base64 32
# ou
# python -c "import secrets; print(secrets.token_urlsafe(32))"

# ========================================
# AMBIENTE
# ========================================
ENVIRONMENT=production
DEBUG=False

# ========================================
# DJANGO
# ========================================
# GERE UMA NOVA: openssl rand -base64 50
SECRET_KEY=GERE_UMA_SENHA_SEGURA_DE_50_CARACTERES_AQUI_NAO_USE_ESTE_VALOR

# Domínios permitidos (separados por vírgula)
ALLOWED_HOSTS=seu-dominio.com.br,localhost,127.0.0.1

# ========================================
# DOMÍNIO
# ========================================
DOMAIN=seu-dominio.com.br
BACKEND_URL=https://seu-dominio.com.br
FRONTEND_URL=https://seu-dominio.com.br

# ========================================
# DATABASE (PostgreSQL)
# ========================================
DB_NAME=verus_ai
DB_USER=verus_ai
# GERE UMA NOVA: openssl rand -base64 32
DB_PASSWORD=GERE_UMA_SENHA_DE_32_CARACTERES_OU_MAIS_AQUI
DB_HOST=db
DB_PORT=5432
# Será montada automaticamente com os valores acima
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ========================================
# REDIS
# ========================================
# GERE UMA NOVA: openssl rand -base64 32
REDIS_PASSWORD=GERE_UMA_SENHA_DE_32_CARACTERES_OU_MAIS_AQUI
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ========================================
# CELERY
# ========================================
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# ========================================
# AI/LLM - OPENAI
# ========================================
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-SUA_CHAVE_AQUI

# ========================================
# AI/LLM - ANTHROPIC (Claude)
# ========================================
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-SUA_CHAVE_AQUI

# ========================================
# AI/LLM - IBM WATSONX.AI
# ========================================
# Obtenha em: https://cloud.ibm.com/
WATSONX_API_KEY=SUA_API_KEY_WATSONX_AQUI
WATSONX_PROJECT_ID=SEU_PROJECT_ID_AQUI
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ========================================
# PESQUISA JURISPRUDENCIAL - TAVILY
# ========================================
# Obtenha em: https://tavily.com/
# Necessário para pesquisa de jurisprudência
TAVILY_API_KEY=tvly-SUA_CHAVE_AQUI
TAVILY_MAX_RESULTS=8
TAVILY_SEARCH_DEPTH=advanced

# ========================================
# AI - PROVEDOR PADRÃO
# ========================================
DEFAULT_LLM_PROVIDER=anthropic

# ========================================
# TINYMCE (Editor WYSIWYG)
# ========================================
# Obtenha em: https://www.tiny.cloud/
TINYMCE_API_KEY=SUA_CHAVE_TINYMCE_AQUI
NEXT_PUBLIC_TINYMCE_API_KEY=SUA_CHAVE_TINYMCE_AQUI

# ========================================
# EMAIL (Produção)
# ========================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@verus.ai
# Use App Password do Google, não a senha normal
EMAIL_HOST_PASSWORD=SUA_APP_PASSWORD_AQUI

# ========================================
# STORAGE - Cloudflare R2 (S3 Compatible)
# ========================================
USE_S3=True
AWS_ACCESS_KEY_ID=SUA_ACCESS_KEY_R2
AWS_SECRET_ACCESS_KEY=SUA_SECRET_KEY_R2
AWS_STORAGE_BUCKET_NAME=seu-bucket
AWS_S3_ENDPOINT_URL=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto
AWS_S3_CUSTOM_DOMAIN=seu-bucket.seu-dominio.com

# ========================================
# SENTRY (Monitoramento de Erros)
# ========================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ========================================
# NEXT.JS (Frontend)
# ========================================
# NEXT_PUBLIC_API_URL: deixe VAZIO em produção (Traefik roteia /api/* para o backend).
# Em dev local, defina como http://localhost:8000.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_BASE_PATH=/api/v1
NEXT_PUBLIC_APP_NAME=Verus.AI
NEXT_PUBLIC_APP_VERSION=1.0.0

# ========================================
# SSL/HTTPS (Certbot/Let's Encrypt)
# ========================================
CERTBOT_EMAIL=infra@verus.ai
LETSENCRYPT_STAGING=0

# ========================================
# SEGURANÇA
# ========================================
CORS_ALLOWED_ORIGINS=https://seu-dominio.com.br
CSRF_TRUSTED_ORIGINS=https://seu-dominio.com.br
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ========================================
# AUTENTICAÇÃO & SEGURANÇA AVANÇADA
# ========================================
# Gere chaves de 256 bits: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode().rstrip('='))"
APP_BASE_URL=${BACKEND_URL}
FRONTEND_URL=${FRONTEND_URL}
JWT_SECRET=GERE_UMA_CHAVE_DE_256_BITS_AQUI
JWT_REFRESH_SECRET=GERE_UMA_CHAVE_DE_256_BITS_AQUI
EMAIL_TOKEN_SECRET=GERE_UMA_CHAVE_DE_256_BITS_AQUI
PASSWORD_RESET_SECRET=GERE_UMA_CHAVE_DE_256_BITS_AQUI
TOKEN_EXPIRATION_CONFIRM=30d
TOKEN_EXPIRATION_RESET=1h
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60000
EMAIL_PROVIDER_API_KEY=SUA_CHAVE_EMAIL_PROVIDER_AQUI
EMAIL_FROM=noreply@verus.ai
HASH_COST=12

# ========================================
# LOGS
# ========================================
LOG_LEVEL=INFO
